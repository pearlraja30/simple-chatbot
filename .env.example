# REQUIRED: For LLM responses (Groq is fast and has a free tier)
GROQ_API_KEY=gsk_your_key_here

# REQUIRED FOR RAG: For query embeddings (Hugging Face is free for MiniLM-384)
# Get a free token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# OPTIONAL: Alternative embedding provider (1536 dims)
# OPENAI_API_KEY=sk-your_key_here

# INTERNAL: Data path for the knowledge base
DATA_PATH=data/embedding.json
